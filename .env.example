# Auth mode: auto | local | supabase
# auto     -> use Supabase when keys exist, else fallback to local offline auth
# local    -> force offline local auth only
# supabase -> force Supabase and fail if unreachable
VITE_AUTH_MODE=auto

# Supabase project settings (required only when using Supabase)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
