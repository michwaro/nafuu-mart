# Auth mode: auto | clerk | local | supabase
# auto     -> use Clerk when configured, else Supabase when keys exist, else fallback to local offline auth
# clerk    -> force Clerk-hosted auth UI and session handling
# local    -> force offline local auth only
# supabase -> force Supabase and fail if unreachable
VITE_AUTH_MODE=auto

# Clerk (Phase 1 scaffolding)
# Add publishable key to enable ClerkProvider in the frontend.
VITE_CLERK_PUBLISHABLE_KEY=REPLACE_WITH_CLERK_PUBLISHABLE_KEY
VITE_API_BASE_URL=http://localhost:4000

# Backend-only Clerk and Neon values (do not expose in frontend code)
CLERK_SECRET_KEY=REPLACE_WITH_CLERK_SECRET_KEY
NEON_DATABASE_URL=REPLACE_WITH_NEON_DATABASE_URL
PORT=4000
CORS_ORIGIN=http://localhost:5173

# Supabase project settings (required only when using Supabase)
VITE_SUPABASE_URL=REPLACE_WITH_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=REPLACE_WITH_SUPABASE_ANON_KEY

# Pesapal payment gateway configuration
# Get these credentials from https://www.pesapal.com
# Use sandbox for testing: https://cybqa.pesapal.com/pesapalv3
# Use production: https://pay.pesapal.com/v3
# Backend server credentials (authoritative)
PESAPAL_CONSUMER_KEY=REPLACE_WITH_PESAPAL_CONSUMER_KEY
PESAPAL_CONSUMER_SECRET=REPLACE_WITH_PESAPAL_CONSUMER_SECRET
PESAPAL_IPN_ID=REPLACE_WITH_PESAPAL_IPN_ID
PESAPAL_BASE_URL=https://cybqa.pesapal.com/pesapalv3

# Daraja M-Pesa STK configuration (real integration)
# Get credentials from Safaricom Daraja portal.
# Sandbox base URL: https://sandbox.safaricom.co.ke
# Production base URL: https://api.safaricom.co.ke
MPESA_CONSUMER_KEY=REPLACE_WITH_DARAJA_CONSUMER_KEY
MPESA_CONSUMER_SECRET=REPLACE_WITH_DARAJA_CONSUMER_SECRET
MPESA_SHORTCODE=REPLACE_WITH_MPESA_SHORTCODE
MPESA_PASSKEY=REPLACE_WITH_MPESA_PASSKEY
MPESA_CALLBACK_URL=REPLACE_WITH_PUBLIC_HTTPS_CALLBACK_URL
MPESA_BASE_URL=https://sandbox.safaricom.co.ke

# Optional: simulation mode for pre-live testing without Daraja live credentials.
# true  -> use deterministic mock STK responses
# false -> require real MPESA_SHORTCODE and MPESA_PASSKEY
MPESA_SIMULATION=false

# AI blog generation provider settings
# LLM_PROVIDER options: github | openai | anthropic | grok
LLM_PROVIDER=github

# GitHub Models (default provider)
GITHUB_TOKEN=REPLACE_WITH_GITHUB_TOKEN
LLM_MODEL=openai/gpt-5-mini
LLM_API_URL=https://models.github.ai/inference/chat/completions

# OpenAI provider
OPENAI_API_KEY=REPLACE_WITH_OPENAI_API_KEY
OPENAI_MODEL=gpt-5-mini
OPENAI_API_URL=https://api.openai.com/v1/chat/completions

# Claude / Anthropic provider
ANTHROPIC_API_KEY=REPLACE_WITH_ANTHROPIC_API_KEY
CLAUDE_API_KEY=REPLACE_WITH_CLAUDE_API_KEY
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages

# Grok / xAI provider
XAI_API_KEY=REPLACE_WITH_XAI_API_KEY
GROK_API_KEY=REPLACE_WITH_GROK_API_KEY
XAI_MODEL=grok-3-mini
XAI_API_URL=https://api.x.ai/v1/chat/completions
